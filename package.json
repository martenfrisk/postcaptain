{
  "name": "postcaptain",
  "version": "0.0.1",
  "description": "Local-first AI work mentor — passive capture + a disciplined insight layer.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Mårten Frisk",
  "bin": {
    "postcaptain": "src/cli.ts"
  },
  "scripts": {
    "capture": "bun run src/cli.ts capture",
    "stats": "bun run src/cli.ts stats",
    "insights": "bun run src/cli.ts insights",
    "ask": "bun run src/cli.ts ask",
    "digest": "bun run src/cli.ts digest",
    "digest:explore": "bun run src/cli.ts digest --explore",
    "digest:send": "bun run src/cli.ts digest --explore --send",
    "serve": "bun run src/cli.ts serve",
    "seed": "bun run scripts/seed-synthetic.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "check": "biome check --write . && tsc --noEmit && bun test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
