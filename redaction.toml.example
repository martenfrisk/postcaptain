# Redaction config (design §8) — the tier + the denylist safety net.
#
# Copy to `redaction.toml` (git-ignored) and fill in your environment's
# identifiers.

# Redaction tier for anything that goes remote (override per-run with --redact):
#   strict       — strip code, mask secrets, pseudonymize ALL identifiers (HMAC tokens)
#   identifiers  — strip code, mask secrets, keep repo/ticket/host/path names readable  (default)
#   raw          — keep verbatim prompts/code + identifiers; mask secrets only
# Secret masking + the fail-closed secret-shape self-check run at EVERY tier —
# a leaked credential never goes remote regardless of this setting.
level = "identifiers"

# Denylist — only force-pseudonymized at the `strict` tier (a small, hand-
# maintained list, NOT a classifier). At `identifiers`/`raw` these names are
# intentionally kept readable. Generic code/secret stripping runs regardless.

# Company / product domains → host:xxxx
company_domains = ["example-corp.com", "internal.example-corp.com"]

# GitHub (or other) orgs → repo:xxxx
repo_orgs = ["example-corp", "example-corp-labs"]

# Extra repo names to force-pseudonymize → repo:xxxx
repo_names = ["checkout-service", "pricing-engine"]

# Internal hostnames (Jira, git, CI, …) → host:xxxx
internal_hosts = ["jira.example-corp.com", "git.example-corp.com"]

# Optional extra people names to mask → user:xxxx
people = []
